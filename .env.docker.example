# docker compose 전용 .env 템플릿 — `cp .env.docker.example .env` 후 그대로 사용 가능.
# 호스트가 localhost가 아니라 compose 서비스명(db, redis)인 점이 네이티브용 .env.example과 다름.

# ── 필수 (compose 서비스명 기준) ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/price_transmission
REDIS_URL=redis://redis:6379/0

# ── 앱 동작 ───────────────────────────────────────────────────
APP_ENV=production           # production: DB/Redis 실패 시 기동 중단(CFG-CORE-001)
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Redis 캐싱 ────────────────────────────────────────────────
REDIS_TTL=3600
REDIS_CACHE_PREFIX=pricelens

# ── 배치 스케줄 (컨테이너에는 pipeline/ 없음 → 실제 재계산 비활성) ──
BATCH_SCHEDULE_DAY=15
BATCH_SCHEDULE_HOUR=3
BATCH_SCHEDULE_TZ=Asia/Seoul

# 데이터 수집 API 키는 서빙 컨테이너에 불필요 — 비워둠.
