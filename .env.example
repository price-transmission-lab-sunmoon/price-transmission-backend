# 필수 환경 변수
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/price_transmission
REDIS_URL=redis://localhost:6379/0

# 선택 환경 변수
APP_ENV=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 파이프라인 파라미터 (pipeline_output_spec_vN §파라미터 표)
ROLLING_WINDOW=48
CONTAMINATION=0.10
RANDOM_STATE=42

# 앱 버전 (선택)
FRAME_VERSION=0.1.0

# doc1_technical_pipeline 현재 버전 — docs/docs_manifest.md §1 표와 일치해야 함
# 버전 갱신 시 manifest §1을 먼저 업데이트한 뒤 이 값을 변경한다
PIPELINE_SPEC_VERSION=v10
