# 필수 환경 변수
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/price_transmission
REDIS_URL=redis://localhost:6379/0

# 선택 환경 변수
APP_ENV=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 파이프라인 파라미터 (pipeline_output_spec_v5 §파라미터 표)
ROLLING_WINDOW=48
CONTAMINATION=0.10
RANDOM_STATE=42

# 앱 버전 (선택)
FRAME_VERSION=0.1.0
