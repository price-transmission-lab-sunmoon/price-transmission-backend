# ── 필수 ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/price_transmission
REDIS_URL=redis://localhost:6379/0

# ── 선택 (기본값 있음) ────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── 파이프라인 데이터 경로 ────────────────────────────────────
PIPELINE_DATA_ROOT=data/processed   # 파이프라인 CSV/JSON 출력 루트

# ── 배치 스케줄 ───────────────────────────────────────────────
BATCH_SCHEDULE_DAY=15
BATCH_SCHEDULE_HOUR=3
BATCH_SCHEDULE_TZ=Asia/Seoul

# ── Redis 캐싱 ────────────────────────────────────────────────
REDIS_TTL=3600
REDIS_CACHE_PREFIX=pricelens

# ── 파이프라인 파라미터 ───────────────────────────────────────
ROLLING_WINDOW=48
CONTAMINATION=0.10
RANDOM_STATE=42

# ── Phase 0 데이터 수집 API 키 ────────────────────────────────
# 한국은행 ECOS Open API (https://ecos.bok.or.kr/api)
ECOS_API_KEY=

# 관세청 수출입 무역통계 Open API
EXIM_API_KEY=

# KAMIS 농산물유통정보 API
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# ── 앱 버전 ───────────────────────────────────────────────────
FRAME_VERSION=0.1.0
PIPELINE_SPEC_VERSION=v10
